class Animal:
    def __init__(self, name):
        self.name = name

    def sound(self):
        print("Animal sound")


class Dog(Animal):
    def __init__(self, name):
        super().__init__(name)

    def sound(self):
        print("gau gau!")




d = Dog(input("nhap ten con cho: "))
print(d.name)
d.sound()

